generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATIONS
  RND
  VIEWER
}

enum WorkflowEscalationType {
  DUPLICATE_JOB
  LOT_CONFLICT
  VALIDATION_ERROR
  PACKING_POLICY_BLOCK
  AUDIT_LOG_FAILURE
  OPERATIONAL_BLOCK
}

enum WorkflowEscalationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkflowEscalationStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum RndJobStatus {
  CREATED
  READY_FOR_TEST_SETUP
  READY_FOR_TESTING
  IN_TESTING
  AWAITING_REVIEW
  APPROVED
  COMPLETED
  REWORK_REQUIRED
}

enum RndJobType {
  INITIAL_TEST
  RETEST
  CLIENT_REQUESTED_RETEST
  BACKUP_TEST
  RETAIN_TEST
}

enum RndReviewAction {
  APPROVE
  REJECT
  REWORK
}

enum PacketUsageEntryType {
  ALLOCATE
  CONSUME
  RELEASE
  RECLASSIFY
  ADJUST
}

enum PacketUsageDirection {
  IN
  OUT
}

enum ResultPrecedenceStatus {
  ACTIVE
  SUPERSEDED
}

model User {
  id                  String    @id
  companyId           String
  email               String?   @unique
  passwordHash        String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  role                UserRole  @default(VIEWER)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  profile UserProfile?

  createdJobs              InspectionJob[] @relation("InspectionJobCreatedBy")
  assignedJobs             InspectionJob[] @relation("InspectionJobAssignedTo")
  assignedJobsAuthored     InspectionJob[] @relation("InspectionJobAssignedBy")
  assignedLots             InspectionLot[] @relation("InspectionLotAssignedTo")
  assignedLotsAuthored     InspectionLot[] @relation("InspectionLotAssignedBy")
  samplesCreated           Sample[]        @relation("SampleCreatedBy")
  sampleEventsPerformed    SampleEvent[]   @relation("SampleEventPerformedBy")
  sampleMediaCaptured      SampleMedia[]   @relation("SampleMediaCapturedBy")
  packetsCreated           Packet[]        @relation("PacketCreatedBy")
  packetEventsPerformed    PacketEvent[]   @relation("PacketEventPerformedBy")
  packetMediaCaptured      PacketMedia[]   @relation("PacketMediaCapturedBy")
  inspections              Inspection[]    @relation("InspectionInspector")
  auditLogs                AuditLog[]
  loginAttempts            LoginAttempt[]
  raisedEscalations        WorkflowEscalation[] @relation("WorkflowEscalationRaisedBy")
  assignedEscalations      WorkflowEscalation[] @relation("WorkflowEscalationAssignedTo")
  assignedRndJobs          RndJob[]             @relation("RndJobAssignedTo")
  approverRndJobs          RndJob[]             @relation("RndJobApprover")
  uploadedRndAttachments   RndJobAttachment[]   @relation("RndJobAttachmentUploadedBy")
  rndReviews               RndJobReview[]       @relation("RndJobReviewedBy")
  packetUsageLedgerEntries PacketUsageLedger[]  @relation("PacketUsageLedgerCreatedBy")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  companyId String
  email     String
  ipAddress String
  userId    String?
  success   Boolean
  outcome   String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, email, createdAt])
  @@index([ipAddress, createdAt])
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  companyName String?
  jobTitle    String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientMaster {
  id            String   @id @default(cuid())
  companyId     String
  clientName    String
  billToAddress String
  shipToAddress String
  gstOrId       String?
  contactPerson String?
  contactNumber String?
  email         String?
  sameAsBilling Boolean  @default(true)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, clientName])
  @@index([companyId])
}

model TransporterMaster {
  id              String   @id @default(cuid())
  companyId       String
  transporterName String
  contactPerson   String?
  phone           String?
  email           String?
  address         String?
  gstOrId         String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, transporterName])
  @@index([companyId])
}

model ItemMaster {
  id          String   @id @default(cuid())
  companyId   String
  itemName    String
  materialType String?
  description String?
  uom         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, itemName])
  @@index([companyId])
}

model ContainerTypeMaster {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model ModuleWorkflowSettings {
  id                          String   @id @default(cuid())
  companyId                   String   @unique
  creatorIsDefaultAssignee    Boolean  @default(true)
  deadlineRequired            Boolean  @default(false)
  decisionRequiredBeforeSampling Boolean @default(true)
  submitToRndEnabled          Boolean  @default(true)
  allowJobCollaborators       Boolean  @default(true)
  autoLotNumbering            Boolean  @default(false)
  lotNumberPrefix             String?
  lotNumberSequenceFormat     String?
  autoSampleIdGeneration      Boolean  @default(true)
  sampleIdPrefix              String?
  sampleIdSequenceFormat      String?
  autoPacketIdGeneration      Boolean  @default(true)
  packetIdPrefix              String?
  packetIdSequenceFormat      String?
  finalDecisionApproverPolicy String   @default("MANAGER_ADMIN")
  lockPacketEditingAfterRndSubmit Boolean @default(true)
  sealScanRequired            Boolean  @default(true)
  imageTimestampRequired      Boolean  @default(false)
  requiredImageCategories     String[]
  optionalImageCategories     String[]
  hiddenImageCategories       String[]
  bulkSealGenerationEnabled   Boolean  @default(true)
  sealEditPolicy              String   @default("ADMIN_ONLY")
  sealEditRoles               String[]
  containerTypeSource         String   @default("MASTER_ONLY")
  homogeneousProofRequired    Boolean  @default(true)
  packetPurposeMode           String   @default("OPTIONAL")
  holdRejectNotesMandatory    Boolean  @default(true)
  notifyOnAssign              Boolean  @default(true)
  notifyOnSubmit              Boolean  @default(true)
  notifyOnDecision            Boolean  @default(true)
  allowedModuleIds            String[]
  showOptionalImageSection    Boolean  @default(true)
  showBlockersInline          Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model CompanyProfileSettings {
  id             String   @id @default(cuid())
  companyId      String   @unique
  companyName    String?
  legalName      String?
  billingAddress String?
  shippingAddress String?
  sameAsBilling  Boolean  @default(true)
  gstNumber      String?
  cinOrRegistration String?
  contactPerson  String?
  contactNumber  String?
  email          String?
  website        String?
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  supportColor   String?
  reportHeaderName String?
  packingListHeaderName String?
  coaHeaderName  String?
  footerText     String?
  signatureName  String?
  signatureTitle String?
  stampImageUrl  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model WarehouseMaster {
  id            String   @id @default(cuid())
  companyId     String
  warehouseName String
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, warehouseName])
  @@index([companyId])
}

model InspectionJob {
  inspectionSerialNumber String @unique
  id                     String @id @default(cuid())
  companyId              String
  jobReferenceNumber     String @unique @default(uuid())

  clientName    String
  clientId      String?
  commodity     String
  itemId        String?
  materialType  String?
  plantLocation String?
  deadline      DateTime?

  status String @default("PENDING")

  createdByUserId String
  assignedToId    String?
  assignedById    String?
  assignedAt      DateTime?
  jobStartedAt    DateTime?
  sentToAdminAt   DateTime?
  sentToAdminBy   String?
  finalDecisionStatus String?
  finalDecisionAt DateTime?
  finalDecisionBy String?
  finalDecisionNote String?
  adminDecisionAt DateTime?
  adminDecisionBy String?
  adminDecisionStatus String?
  operationsCompletedAt DateTime?
  handedOverToRndAt DateTime?
  handedOverToRndBy String?
  handedOverToRndTo String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lots               InspectionLot[]
  inspections        Inspection[]
  experiments        RDExperiment[]
  mediaFiles         MediaFile[]         @relation("JobMediaFiles")
  samples            Sample[]
  homogeneousSamples HomogeneousSample[]
  reportSnapshots    ReportSnapshot[]
  auditLogs          AuditLog[]
  packets            Packet[]
  workflowEscalations WorkflowEscalation[]
  rndJobs            RndJob[]

  createdByUser User  @relation("InspectionJobCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignedTo    User? @relation("InspectionJobAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedBy    User? @relation("InspectionJobAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, assignedToId])
  @@index([createdByUserId])
}

model AuditLog {
  id        String   @id @default(cuid())
  jobId     String
  userId    String
  entity    String   @default("JOB")
  action    String // e.g. "STATUS_CHANGE"
  from      String?
  to        String?
  notes     String?
  metadata  Json?
  createdAt DateTime @default(now())

  job  InspectionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model ReportSnapshot {
  id        String   @id @default(cuid())
  jobId     String
  data      Json
  createdAt DateTime @default(now())

  job               InspectionJob      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rndReportVersions RndReportVersion[]
}

model InspectionLot {
  id               String  @id @default(cuid())
  jobId            String
  companyId        String
  lotNumber        String
  isAutoGenerated  Boolean @default(false)
  materialName     String?
  materialCategory String?
  quantityMode     String  @default("SINGLE_PIECE")
  bagCount         Int?
  pieceCount       Int?
  weightUnit       String?
  remarks          String?

  totalBags Int @default(1)

  grossWeightKg    Decimal?
  netWeightKg      Decimal?
  sealNumber       String?  @unique
  sealAuto         Boolean  @default(false)
  grossWeight      Float?
  tareWeight       Float?
  netWeight        Float?
  bagPhotoUrl      String?
  samplingPhotoUrl String?
  sealPhotoUrl     String?

  status       String    @default("PENDING")
  assignedToId String?
  assignedById String?
  assignedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  job        InspectionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  mediaFiles MediaFile[]   @relation("LotMediaFiles")
  inspection Inspection?
  sample     Sample?
  trials     RDTrial[]     @relation("LotTrials")
  packets    Packet[]
  rndJobs    RndJob[]
  assignedTo User?         @relation("InspectionLotAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedBy User?         @relation("InspectionLotAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  bags     InspectionBag[]
  workflowEscalations WorkflowEscalation[]

  @@unique([jobId, lotNumber])
  @@index([companyId])
  @@index([companyId, assignedToId])
  @@index([companyId, sealNumber])
}

model WorkflowEscalation {
  id             String                   @id @default(cuid())
  companyId      String
  type           WorkflowEscalationType
  severity       WorkflowEscalationSeverity @default(MEDIUM)
  status         WorkflowEscalationStatus @default(OPEN)
  title          String
  detailsJson    Json?
  overrideReason String?
  resolutionNote String?
  jobId          String?
  lotId          String?
  raisedByUserId String?
  assignedToUserId String?
  resolvedAt     DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  job          InspectionJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  lot          InspectionLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  raisedByUser User?          @relation("WorkflowEscalationRaisedBy", fields: [raisedByUserId], references: [id], onDelete: SetNull)
  assignedToUser User?        @relation("WorkflowEscalationAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status, createdAt(sort: Desc)])
  @@index([companyId, type, createdAt(sort: Desc)])
  @@index([jobId])
  @@index([lotId])
}

model MediaFile {
  id        String @id @default(cuid())
  companyId String

  jobId             String?
  lotId             String?
  inspectionId      String?
  inspectionIssueId String?

  category   String
  storageKey String
  fileName   String

  createdAt DateTime @default(now())

  job             InspectionJob?   @relation("JobMediaFiles", fields: [jobId], references: [id], onDelete: Cascade)
  lot             InspectionLot?   @relation("LotMediaFiles", fields: [lotId], references: [id], onDelete: Cascade)
  inspection      Inspection?      @relation("InspectionMediaFiles", fields: [inspectionId], references: [id], onDelete: Cascade)
  inspectionIssue InspectionIssue? @relation("InspectionIssueMediaFiles", fields: [inspectionIssueId], references: [id], onDelete: SetNull)

  @@index([inspectionId, createdAt])
  @@index([inspectionIssueId, createdAt])
}

model Inspection {
  id                  String    @id @default(cuid())
  jobId               String
  lotId               String    @unique
  inspectorId         String
  inspectionStatus    String    @default("IN_PROGRESS")
  decisionStatus      String    @default("PENDING")
  startedAt           DateTime  @default(now())
  sentToAdminAt       DateTime?
  sentToAdminBy       String?
  decisionAt          DateTime?
  decisionBy          String?
  decisionOutcome     String?
  completedAt         DateTime?
  overallRemark       String?
  identityRiskFlag    Boolean   @default(false)
  packagingRiskFlag   Boolean   @default(false)
  materialRiskFlag    Boolean   @default(false)
  samplingBlockedFlag Boolean   @default(true)
  issueCount          Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  job        InspectionJob                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lot        InspectionLot                 @relation(fields: [lotId], references: [id], onDelete: Cascade)
  inspector  User                          @relation("InspectionInspector", fields: [inspectorId], references: [id], onDelete: Restrict)
  responses  InspectionChecklistResponse[]
  issues     InspectionIssue[]
  mediaFiles MediaFile[]                   @relation("InspectionMediaFiles")
  sample     Sample?

  @@index([jobId, createdAt])
  @@index([inspectorId, createdAt])
}

model InspectionChecklistItemMaster {
  id               String   @id @default(cuid())
  itemKey          String   @unique
  sectionName      String
  itemLabel        String
  responseType     String
  isRequired       Boolean  @default(true)
  materialCategory String?
  displayOrder     Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  responses InspectionChecklistResponse[]

  @@index([isActive, displayOrder])
}

model InspectionChecklistResponse {
  id                    String   @id @default(cuid())
  inspectionId          String
  checklistItemMasterId String
  sectionName           String
  itemLabel             String
  responseValue         String?
  responseText          String?
  isException           Boolean  @default(false)
  displayOrder          Int
  recordedAt            DateTime @default(now())

  inspection          Inspection                    @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  checklistItemMaster InspectionChecklistItemMaster @relation(fields: [checklistItemMasterId], references: [id], onDelete: Restrict)

  @@unique([inspectionId, checklistItemMasterId])
  @@index([inspectionId, displayOrder])
}

model InspectionIssue {
  id            String   @id @default(cuid())
  inspectionId  String
  issueCategory String
  severity      String
  description   String
  status        String   @default("OPEN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inspection Inspection  @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  mediaFiles MediaFile[] @relation("InspectionIssueMediaFiles")

  @@index([inspectionId, createdAt])
  @@index([inspectionId, status])
}

model RDExperiment {
  id    String @id @default(cuid())
  jobId String

  title      String
  hypothesis String?
  status     String  @default("DRAFT")

  createdAt DateTime @default(now())

  job    InspectionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  trials RDTrial[]
}

model RDTrial {
  id           String @id @default(cuid())
  experimentId String

  lotId String?
  packetId String? @unique

  trialNumber Int
  notes       String?

  grossWeightKg Decimal?
  netWeightKg   Decimal?

  createdAt DateTime @default(now())

  experiment RDExperiment   @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  lot        InspectionLot? @relation("LotTrials", fields: [lotId], references: [id], onDelete: Cascade)
  packet     Packet?        @relation(fields: [packetId], references: [id], onDelete: SetNull)

  measurements RDMeasurement[]
}

model RDMeasurement {
  id      String @id @default(cuid())
  trialId String

  element String
  value   Decimal

  createdAt DateTime @default(now())

  trial RDTrial @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@unique([trialId, element])
}

model InspectionBag {
  id    String @id @default(cuid())
  lotId String

  bagNumber   Int
  grossWeight Float?
  netWeight   Float?

  createdAt DateTime @default(now())

  lot InspectionLot @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@unique([lotId, bagNumber])
}

model SerialCounter {
  id      String @id @default(cuid())
  year    Int    @unique
  counter Int
}

model Sample {
  id                  String    @id @default(cuid())
  companyId           String
  jobId               String
  lotId               String?   @unique
  inspectionId        String?   @unique
  sampleCode          String    @unique
  sampleStatus        String    @default("CREATED")
  sampleType          String?
  samplingMethod      String?
  samplingDate        DateTime?
  sampleQuantity      Float?
  sampleUnit          String?
  containerType       String?
  remarks             String?
  homogeneousProofDone Boolean @default(false)
  homogenizedAt       DateTime?
  readyForPacketingAt DateTime?
  createdById         String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  job        InspectionJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lot        InspectionLot?   @relation(fields: [lotId], references: [id], onDelete: SetNull)
  inspection Inspection?      @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  createdBy  User             @relation("SampleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  events     SampleEvent[]
  media      SampleMedia[]
  sealLabel  SampleSealLabel?
  packets    Packet[]
  rndJobs    RndJob[]

  @@unique([jobId])
  @@index([companyId, sampleStatus])
}

model Packet {
  id             String    @id @default(cuid())
  companyId      String
  jobId          String
  lotId          String?
  sampleId       String
  packetCode     String    @unique
  packetNo       Int
  packetStatus   String    @default("CREATED")
  packetQuantity Float?
  packetWeight   Float?
  packetUnit     String?
  packetType     String?
  remarks        String?
  readyAt        DateTime?
  submittedToRndAt DateTime?
  submittedToRndBy String?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  job        InspectionJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lot        InspectionLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  sample     Sample         @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  createdBy  User           @relation("PacketCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  events     PacketEvent[]
  media      PacketMedia[]
  sealLabel  PacketSealLabel?
  allocation PacketAllocation?
  trial      RDTrial?
  rndJobs    RndJob[]
  usageLedgerEntries PacketUsageLedger[]

  @@unique([sampleId, packetNo])
  @@index([companyId, packetStatus])
  @@index([jobId, createdAt])
  @@index([sampleId, packetStatus])
}

model PacketEvent {
  id            String   @id @default(cuid())
  packetId       String
  eventType      String
  eventTime      DateTime @default(now())
  performedById  String?
  remarks        String?
  metadata       Json?
  createdAt      DateTime @default(now())

  packet      Packet @relation(fields: [packetId], references: [id], onDelete: Cascade)
  performedBy User?  @relation("PacketEventPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([packetId, eventTime])
  @@index([eventType, eventTime])
}

model PacketMedia {
  id           String   @id @default(cuid())
  packetId      String
  mediaType     String
  fileUrl       String
  capturedAt    DateTime @default(now())
  capturedById  String?
  remarks       String?
  createdAt     DateTime @default(now())

  packet     Packet @relation(fields: [packetId], references: [id], onDelete: Cascade)
  capturedBy User?  @relation("PacketMediaCapturedBy", fields: [capturedById], references: [id], onDelete: SetNull)

  @@index([packetId, capturedAt])
  @@index([packetId, mediaType])
}

model PacketSealLabel {
  id         String    @id @default(cuid())
  packetId    String    @unique
  sealNo      String?
  labelText   String?
  labelCode   String?
  sealStatus  String?   @default("PENDING")
  sealedAt    DateTime?
  labeledAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  packet Packet @relation(fields: [packetId], references: [id], onDelete: Cascade)
}

model PacketAllocation {
  id                String    @id @default(cuid())
  packetId          String    @unique
  allocationStatus  String    @default("BLOCKED")
  allocatedToType   String?
  allocatedToId     String?
  allocatedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  packet Packet @relation(fields: [packetId], references: [id], onDelete: Cascade)

  @@index([allocationStatus, allocatedAt])
}

model SampleEvent {
  id            String   @id @default(cuid())
  sampleId      String
  eventType     String
  eventTime     DateTime @default(now())
  performedById String?
  remarks       String?
  metadata      Json?
  createdAt     DateTime @default(now())

  sample      Sample @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  performedBy User?  @relation("SampleEventPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([sampleId, eventTime])
  @@index([eventType, eventTime])
}

model SampleMedia {
  id           String   @id @default(cuid())
  sampleId     String
  mediaType    String
  fileUrl      String
  capturedAt   DateTime @default(now())
  capturedById String?
  remarks      String?
  createdAt    DateTime @default(now())

  sample     Sample @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  capturedBy User?  @relation("SampleMediaCapturedBy", fields: [capturedById], references: [id], onDelete: SetNull)

  @@index([sampleId, capturedAt])
  @@index([sampleId, mediaType])
}

model SampleSealLabel {
  id         String    @id @default(cuid())
  sampleId   String    @unique
  sealNo     String?
  labelText  String?
  sealStatus String?   @default("PENDING")
  sealSource String?   @default("MANUAL")
  editableByAdminOnly Boolean @default(false)
  labeledAt  DateTime?
  sealedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sample Sample @relation(fields: [sampleId], references: [id], onDelete: Cascade)
}

model HomogeneousSample {
  id    String @id @default(cuid())
  jobId String

  createdAt DateTime @default(now())
  photoUrl  String?

  job     InspectionJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  packets SamplePacket[]

  @@unique([jobId])
}

model SamplePacket {
  id       String @id @default(cuid())
  sampleId String

  packetNumber Int
  packetCode   String    @unique
  packetStatus String    @default("READY")
  generatedAt  DateTime  @default(now())
  usedAt       DateTime?

  sample HomogeneousSample @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  @@unique([sampleId, packetNumber])
}

model RDStepMaster {
  id                     String   @id @default(cuid())
  companyId              String
  name                   String
  category               String
  defaultDurationSeconds Int      @default(600)
  requiresTimer          Boolean  @default(true)
  allowsChemicals        Boolean  @default(true)
  allowsAssets           Boolean  @default(true)
  requiresAsset          Boolean  @default(false)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([companyId])
  @@map("rd_step_master")
}

model RDChemicalMaster {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  code          String
  category      String
  baseUnit      String
  allowedUnits  String[]
  stockQuantity Float    @default(0)
  reorderLevel  Float    @default(0)
  location      String   @default("")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@map("rd_chemical_master")
}

model RDAssetMaster {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  code            String
  category        String
  availability    String   @default("AVAILABLE")
  location        String   @default("")
  calibrationDate String   @default("")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@map("rd_asset_master")
}

model RDUnitMaster {
  id               String   @id @default(cuid())
  companyId        String
  unitCode         String
  category         String
  conversionToBase Float    @default(1)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
  @@map("rd_unit_master")
}

model RDTemplateMaster {
  id                   String   @id @default(cuid())
  companyId            String
  name                 String
  notes                String   @default("")
  stepNames            String[]
  expectedMeasurements String[]
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([companyId])
  @@map("rd_template_master")
}

model RndJob {
  id              String      @id @default(cuid())
  rndJobNumber    String      @unique
  companyId       String
  parentJobId     String
  lotId           String?
  sampleId        String
  packetId        String
  previousRndJobId String?
  status          RndJobStatus @default(CREATED)
  resultPrecedence ResultPrecedenceStatus @default(ACTIVE)
  jobType         RndJobType   @default(INITIAL_TEST)
  packetUse       String?
  testType        String?
  testMethod      String?
  priority        String       @default("MEDIUM")
  deadline        DateTime?
  assignedToId    String?
  approverUserId  String?
  remarks         String?
  receivedAt      DateTime     @default(now())
  testingStartedAt DateTime?
  resultsSubmittedAt DateTime?
  reviewedAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  parentJob       InspectionJob @relation(fields: [parentJobId], references: [id], onDelete: Cascade)
  lot             InspectionLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  sample          Sample        @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  packet          Packet        @relation(fields: [packetId], references: [id], onDelete: Cascade)
  previousRndJob  RndJob?       @relation("RndJobRetestLineage", fields: [previousRndJobId], references: [id], onDelete: SetNull)
  nextRetestJobs  RndJob[]      @relation("RndJobRetestLineage")
  assignedTo      User?         @relation("RndJobAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  approverUser    User?         @relation("RndJobApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  readings        RndJobReading[]
  attachments     RndJobAttachment[]
  reviews         RndJobReview[]
  reportVersions  RndReportVersion[]
  packetUsageLedgerEntries PacketUsageLedger[]

  @@index([companyId, status, receivedAt(sort: Desc)])
  @@index([companyId, assignedToId])
  @@index([companyId, approverUserId])
  @@index([parentJobId, createdAt(sort: Desc)])
  @@index([packetId])
}

model RndReportVersion {
  id               String                 @id @default(cuid())
  companyId        String
  parentJobId      String
  sampleId         String
  rndJobId         String
  reportSnapshotId String
  precedence       ResultPrecedenceStatus @default(ACTIVE)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  rndJob         RndJob         @relation(fields: [rndJobId], references: [id], onDelete: Cascade)
  reportSnapshot ReportSnapshot @relation(fields: [reportSnapshotId], references: [id], onDelete: Cascade)

  @@index([companyId, parentJobId, sampleId, precedence])
  @@index([rndJobId, createdAt(sort: Desc)])
  @@index([reportSnapshotId])
}

model RndJobReading {
  id         String   @id @default(cuid())
  rndJobId   String
  parameter  String
  value      Decimal
  unit       String?
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rndJob RndJob @relation(fields: [rndJobId], references: [id], onDelete: Cascade)

  @@index([rndJobId, createdAt])
}

model RndJobAttachment {
  id           String   @id @default(cuid())
  rndJobId     String
  fileName     String
  fileUrl      String
  mimeType     String?
  fileSizeBytes Int?
  notes        String?
  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rndJob     RndJob @relation(fields: [rndJobId], references: [id], onDelete: Cascade)
  uploadedBy User?  @relation("RndJobAttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([rndJobId, createdAt])
}

model RndJobReview {
  id           String          @id @default(cuid())
  rndJobId     String
  action       RndReviewAction
  notes        String?
  reviewedById String
  reviewedAt   DateTime        @default(now())
  createdAt    DateTime        @default(now())

  rndJob     RndJob @relation(fields: [rndJobId], references: [id], onDelete: Cascade)
  reviewedBy User   @relation("RndJobReviewedBy", fields: [reviewedById], references: [id], onDelete: Restrict)

  @@index([rndJobId, reviewedAt(sort: Desc)])
}

model PacketUsageLedger {
  id          String               @id @default(cuid())
  companyId   String
  packetId    String
  rndJobId    String?
  entryType   PacketUsageEntryType
  useType     String?
  quantity    Decimal
  unit        String
  direction   PacketUsageDirection
  notes       String?
  createdById String
  createdAt   DateTime             @default(now())

  packet    Packet @relation(fields: [packetId], references: [id], onDelete: Cascade)
  rndJob    RndJob? @relation(fields: [rndJobId], references: [id], onDelete: SetNull)
  createdBy User @relation("PacketUsageLedgerCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([companyId, packetId, createdAt(sort: Desc)])
  @@index([rndJobId, createdAt(sort: Desc)])
}
