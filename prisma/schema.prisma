generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATIONS
  RND
  VIEWER
}

model User {
  id                  String    @id
  companyId           String
  email               String?   @unique
  passwordHash        String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  role                UserRole  @default(VIEWER)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  profile UserProfile?

  createdJobs              InspectionJob[] @relation("InspectionJobCreatedBy")
  assignedJobs             InspectionJob[] @relation("InspectionJobAssignedTo")
  assignedJobsAuthored     InspectionJob[] @relation("InspectionJobAssignedBy")
  assignedLots             InspectionLot[] @relation("InspectionLotAssignedTo")
  assignedLotsAuthored     InspectionLot[] @relation("InspectionLotAssignedBy")
  assignedSampling         Sampling[]      @relation("SamplingAssignedTo")
  assignedSamplingAuthored Sampling[]      @relation("SamplingAssignedBy")
  samplesCreated           Sample[]        @relation("SampleCreatedBy")
  sampleEventsPerformed    SampleEvent[]   @relation("SampleEventPerformedBy")
  sampleMediaCaptured      SampleMedia[]   @relation("SampleMediaCapturedBy")
  packetsCreated           Packet[]        @relation("PacketCreatedBy")
  packetEventsPerformed    PacketEvent[]   @relation("PacketEventPerformedBy")
  packetMediaCaptured      PacketMedia[]   @relation("PacketMediaCapturedBy")
  inspections              Inspection[]    @relation("InspectionInspector")
  auditLogs                AuditLog[]
  loginAttempts            LoginAttempt[]
}

model LoginAttempt {
  id        String   @id @default(cuid())
  companyId String
  email     String
  ipAddress String
  userId    String?
  success   Boolean
  outcome   String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, email, createdAt])
  @@index([ipAddress, createdAt])
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  companyName String?
  jobTitle    String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientMaster {
  id            String   @id @default(cuid())
  companyId     String
  clientName    String
  billToAddress String
  shipToAddress String
  gstOrId       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, clientName])
  @@index([companyId])
}

model TransporterMaster {
  id              String   @id @default(cuid())
  companyId       String
  transporterName String
  contactPerson   String?
  phone           String?
  email           String?
  address         String?
  gstOrId         String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, transporterName])
  @@index([companyId])
}

model ItemMaster {
  id          String   @id @default(cuid())
  companyId   String
  itemName    String
  materialType String?
  description String?
  uom         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, itemName])
  @@index([companyId])
}

model WarehouseMaster {
  id            String   @id @default(cuid())
  companyId     String
  warehouseName String
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, warehouseName])
  @@index([companyId])
}

model InspectionJob {
  inspectionSerialNumber String @unique
  id                     String @id @default(cuid())
  companyId              String
  jobReferenceNumber     String @unique @default(uuid())

  clientName    String
  commodity     String
  materialType  String?
  plantLocation String?

  status String @default("PENDING")

  createdByUserId String
  assignedToId    String?
  assignedById    String?
  assignedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lots               InspectionLot[]
  inspections        Inspection[]
  experiments        RDExperiment[]
  mediaFiles         MediaFile[]         @relation("JobMediaFiles")
  samples            Sample[]
  homogeneousSamples HomogeneousSample[]
  reportSnapshots    ReportSnapshot[]
  auditLogs          AuditLog[]
  packets            Packet[]

  createdByUser User  @relation("InspectionJobCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignedTo    User? @relation("InspectionJobAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedBy    User? @relation("InspectionJobAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, assignedToId])
  @@index([createdByUserId])
}

model AuditLog {
  id        String   @id @default(cuid())
  jobId     String
  userId    String
  entity    String   @default("JOB")
  action    String // e.g. "STATUS_CHANGE"
  from      String?
  to        String?
  notes     String?
  metadata  Json?
  createdAt DateTime @default(now())

  job  InspectionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model ReportSnapshot {
  id        String   @id @default(cuid())
  jobId     String
  data      Json
  createdAt DateTime @default(now())

  job InspectionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model InspectionLot {
  id               String  @id @default(cuid())
  jobId            String
  companyId        String
  lotNumber        String
  materialName     String?
  materialCategory String?
  quantityMode     String  @default("SINGLE_PIECE")
  bagCount         Int?
  pieceCount       Int?
  weightUnit       String?
  remarks          String?

  totalBags Int @default(1)

  grossWeightKg    Decimal?
  netWeightKg      Decimal?
  sealNumber       String?  @unique
  sealAuto         Boolean  @default(false)
  grossWeight      Float?
  tareWeight       Float?
  netWeight        Float?
  bagPhotoUrl      String?
  samplingPhotoUrl String?
  sealPhotoUrl     String?

  status       String    @default("PENDING")
  assignedToId String?
  assignedById String?
  assignedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  job        InspectionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  mediaFiles MediaFile[]   @relation("LotMediaFiles")
  inspection Inspection?
  sample     Sample?
  trials     RDTrial[]     @relation("LotTrials")
  packets    Packet[]
  assignedTo User?         @relation("InspectionLotAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedBy User?         @relation("InspectionLotAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  bags     InspectionBag[]
  sampling Sampling[]

  @@unique([jobId, lotNumber])
  @@index([companyId])
  @@index([companyId, assignedToId])
  @@index([companyId, sealNumber])
}

model MediaFile {
  id        String @id @default(cuid())
  companyId String

  jobId             String?
  lotId             String?
  inspectionId      String?
  inspectionIssueId String?

  category   String
  storageKey String
  fileName   String

  createdAt DateTime @default(now())

  job             InspectionJob?   @relation("JobMediaFiles", fields: [jobId], references: [id], onDelete: Cascade)
  lot             InspectionLot?   @relation("LotMediaFiles", fields: [lotId], references: [id], onDelete: Cascade)
  inspection      Inspection?      @relation("InspectionMediaFiles", fields: [inspectionId], references: [id], onDelete: Cascade)
  inspectionIssue InspectionIssue? @relation("InspectionIssueMediaFiles", fields: [inspectionIssueId], references: [id], onDelete: SetNull)

  @@index([inspectionId, createdAt])
  @@index([inspectionIssueId, createdAt])
}

model Inspection {
  id                  String    @id @default(cuid())
  jobId               String
  lotId               String    @unique
  inspectorId         String
  inspectionStatus    String    @default("IN_PROGRESS")
  decisionStatus      String    @default("PENDING")
  startedAt           DateTime  @default(now())
  completedAt         DateTime?
  overallRemark       String?
  identityRiskFlag    Boolean   @default(false)
  packagingRiskFlag   Boolean   @default(false)
  materialRiskFlag    Boolean   @default(false)
  samplingBlockedFlag Boolean   @default(true)
  issueCount          Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  job        InspectionJob                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lot        InspectionLot                 @relation(fields: [lotId], references: [id], onDelete: Cascade)
  inspector  User                          @relation("InspectionInspector", fields: [inspectorId], references: [id], onDelete: Restrict)
  responses  InspectionChecklistResponse[]
  issues     InspectionIssue[]
  mediaFiles MediaFile[]                   @relation("InspectionMediaFiles")
  sample     Sample?

  @@index([jobId, createdAt])
  @@index([inspectorId, createdAt])
}

model InspectionChecklistItemMaster {
  id               String   @id @default(cuid())
  itemKey          String   @unique
  sectionName      String
  itemLabel        String
  responseType     String
  isRequired       Boolean  @default(true)
  materialCategory String?
  displayOrder     Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  responses InspectionChecklistResponse[]

  @@index([isActive, displayOrder])
}

model InspectionChecklistResponse {
  id                    String   @id @default(cuid())
  inspectionId          String
  checklistItemMasterId String
  sectionName           String
  itemLabel             String
  responseValue         String?
  responseText          String?
  isException           Boolean  @default(false)
  displayOrder          Int
  recordedAt            DateTime @default(now())

  inspection          Inspection                    @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  checklistItemMaster InspectionChecklistItemMaster @relation(fields: [checklistItemMasterId], references: [id], onDelete: Restrict)

  @@unique([inspectionId, checklistItemMasterId])
  @@index([inspectionId, displayOrder])
}

model InspectionIssue {
  id            String   @id @default(cuid())
  inspectionId  String
  issueCategory String
  severity      String
  description   String
  status        String   @default("OPEN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inspection Inspection  @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  mediaFiles MediaFile[] @relation("InspectionIssueMediaFiles")

  @@index([inspectionId, createdAt])
  @@index([inspectionId, status])
}

model RDExperiment {
  id    String @id @default(cuid())
  jobId String

  title      String
  hypothesis String?
  status     String  @default("DRAFT")

  createdAt DateTime @default(now())

  job    InspectionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  trials RDTrial[]
}

model RDTrial {
  id           String @id @default(cuid())
  experimentId String

  lotId String?
  packetId String? @unique

  trialNumber Int
  notes       String?

  grossWeightKg Decimal?
  netWeightKg   Decimal?

  createdAt DateTime @default(now())

  experiment RDExperiment   @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  lot        InspectionLot? @relation("LotTrials", fields: [lotId], references: [id], onDelete: Cascade)
  packet     Packet?        @relation(fields: [packetId], references: [id], onDelete: SetNull)

  measurements RDMeasurement[]
}

model RDMeasurement {
  id      String @id @default(cuid())
  trialId String

  element String
  value   Decimal

  createdAt DateTime @default(now())

  trial RDTrial @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@unique([trialId, element])
}

model InspectionBag {
  id    String @id @default(cuid())
  lotId String

  bagNumber   Int
  grossWeight Float?
  netWeight   Float?

  createdAt DateTime @default(now())

  lot InspectionLot @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@unique([lotId, bagNumber])
}

model SerialCounter {
  id      String @id @default(cuid())
  year    Int    @unique
  counter Int
}

model Sample {
  id                  String    @id @default(cuid())
  companyId           String
  jobId               String
  lotId               String    @unique
  inspectionId        String    @unique
  sampleCode          String    @unique
  sampleStatus        String    @default("CREATED")
  sampleType          String?
  samplingMethod      String?
  samplingDate        DateTime?
  sampleQuantity      Float?
  sampleUnit          String?
  containerType       String?
  remarks             String?
  homogenizedAt       DateTime?
  readyForPacketingAt DateTime?
  createdById         String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  job        InspectionJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lot        InspectionLot    @relation(fields: [lotId], references: [id], onDelete: Cascade)
  inspection Inspection       @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  createdBy  User             @relation("SampleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  events     SampleEvent[]
  media      SampleMedia[]
  sealLabel  SampleSealLabel?
  packets    Packet[]

  @@index([companyId, sampleStatus])
  @@index([jobId, createdAt])
}

model Packet {
  id             String    @id @default(cuid())
  companyId      String
  jobId          String
  lotId          String
  sampleId       String
  packetCode     String    @unique
  packetNo       Int
  packetStatus   String    @default("CREATED")
  packetQuantity Float?
  packetUnit     String?
  packetType     String?
  remarks        String?
  readyAt        DateTime?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  job        InspectionJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lot        InspectionLot  @relation(fields: [lotId], references: [id], onDelete: Cascade)
  sample     Sample         @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  createdBy  User           @relation("PacketCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  events     PacketEvent[]
  media      PacketMedia[]
  sealLabel  PacketSealLabel?
  allocation PacketAllocation?
  trial      RDTrial?

  @@unique([sampleId, packetNo])
  @@index([companyId, packetStatus])
  @@index([jobId, createdAt])
  @@index([sampleId, packetStatus])
}

model PacketEvent {
  id            String   @id @default(cuid())
  packetId       String
  eventType      String
  eventTime      DateTime @default(now())
  performedById  String?
  remarks        String?
  metadata       Json?
  createdAt      DateTime @default(now())

  packet      Packet @relation(fields: [packetId], references: [id], onDelete: Cascade)
  performedBy User?  @relation("PacketEventPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([packetId, eventTime])
  @@index([eventType, eventTime])
}

model PacketMedia {
  id           String   @id @default(cuid())
  packetId      String
  mediaType     String
  fileUrl       String
  capturedAt    DateTime @default(now())
  capturedById  String?
  remarks       String?
  createdAt     DateTime @default(now())

  packet     Packet @relation(fields: [packetId], references: [id], onDelete: Cascade)
  capturedBy User?  @relation("PacketMediaCapturedBy", fields: [capturedById], references: [id], onDelete: SetNull)

  @@index([packetId, capturedAt])
  @@index([packetId, mediaType])
}

model PacketSealLabel {
  id         String    @id @default(cuid())
  packetId    String    @unique
  sealNo      String?
  labelText   String?
  labelCode   String?
  sealStatus  String?   @default("PENDING")
  sealedAt    DateTime?
  labeledAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  packet Packet @relation(fields: [packetId], references: [id], onDelete: Cascade)
}

model PacketAllocation {
  id                String    @id @default(cuid())
  packetId          String    @unique
  allocationStatus  String    @default("BLOCKED")
  allocatedToType   String?
  allocatedToId     String?
  allocatedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  packet Packet @relation(fields: [packetId], references: [id], onDelete: Cascade)

  @@index([allocationStatus, allocatedAt])
}

model SampleEvent {
  id            String   @id @default(cuid())
  sampleId      String
  eventType     String
  eventTime     DateTime @default(now())
  performedById String?
  remarks       String?
  metadata      Json?
  createdAt     DateTime @default(now())

  sample      Sample @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  performedBy User?  @relation("SampleEventPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([sampleId, eventTime])
  @@index([eventType, eventTime])
}

model SampleMedia {
  id           String   @id @default(cuid())
  sampleId     String
  mediaType    String
  fileUrl      String
  capturedAt   DateTime @default(now())
  capturedById String?
  remarks      String?
  createdAt    DateTime @default(now())

  sample     Sample @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  capturedBy User?  @relation("SampleMediaCapturedBy", fields: [capturedById], references: [id], onDelete: SetNull)

  @@index([sampleId, capturedAt])
  @@index([sampleId, mediaType])
}

model SampleSealLabel {
  id         String    @id @default(cuid())
  sampleId   String    @unique
  sealNo     String?
  labelText  String?
  sealStatus String?   @default("PENDING")
  labeledAt  DateTime?
  sealedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sample Sample @relation(fields: [sampleId], references: [id], onDelete: Cascade)
}

model Sampling {
  id        String @id @default(cuid())
  lotId     String @unique
  companyId String

  beforePhotoUrl String?
  duringPhotoUrl String?
  afterPhotoUrl  String?

  status       String    @default("PENDING")
  assignedToId String?
  assignedById String?
  assignedAt   DateTime?
  createdAt    DateTime  @default(now())

  lot        InspectionLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  assignedTo User?         @relation("SamplingAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedBy User?         @relation("SamplingAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, assignedToId])
}

model HomogeneousSample {
  id    String @id @default(cuid())
  jobId String

  createdAt DateTime @default(now())
  photoUrl  String?

  job     InspectionJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  packets SamplePacket[]

  @@unique([jobId])
}

model SamplePacket {
  id       String @id @default(cuid())
  sampleId String

  packetNumber Int
  packetCode   String    @unique
  packetStatus String    @default("READY")
  generatedAt  DateTime  @default(now())
  usedAt       DateTime?

  sample HomogeneousSample @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  @@unique([sampleId, packetNumber])
}

model RDStepMaster {
  id                     String   @id @default(cuid())
  companyId              String
  name                   String
  category               String
  defaultDurationSeconds Int      @default(600)
  requiresTimer          Boolean  @default(true)
  allowsChemicals        Boolean  @default(true)
  allowsAssets           Boolean  @default(true)
  requiresAsset          Boolean  @default(false)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([companyId])
  @@map("rd_step_master")
}

model RDChemicalMaster {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  code          String
  category      String
  baseUnit      String
  allowedUnits  String[]
  stockQuantity Float    @default(0)
  reorderLevel  Float    @default(0)
  location      String   @default("")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@map("rd_chemical_master")
}

model RDAssetMaster {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  code            String
  category        String
  availability    String   @default("AVAILABLE")
  location        String   @default("")
  calibrationDate String   @default("")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@map("rd_asset_master")
}

model RDUnitMaster {
  id               String   @id @default(cuid())
  companyId        String
  unitCode         String
  category         String
  conversionToBase Float    @default(1)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
  @@map("rd_unit_master")
}

model RDTemplateMaster {
  id                   String   @id @default(cuid())
  companyId            String
  name                 String
  notes                String   @default("")
  stepNames            String[]
  expectedMeasurements String[]
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([companyId])
  @@map("rd_template_master")
}
